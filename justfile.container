# Rust poker examples - container version
# This file is mounted as 'justfile' inside the container
# Also used directly in CI

set shell := ["bash", "-c"]

ROOT := `git rev-parse --show-toplevel`

default:
    @just --list

# Build all workspace crates
build:
    cargo build --workspace

# Build release binaries
build-release:
    cargo build --workspace --release

# Run all tests
test:
    cargo test --workspace

# Run clippy linter
lint:
    cargo clippy --workspace -- -D warnings

# Check formatting (use fmt-fix to auto-format)
fmt:
    cargo fmt --check

# Auto-format code
fmt-fix:
    cargo fmt

# Check code compiles
check:
    cargo check --workspace

# Run all checks (build + test + lint + fmt)
check-all: build test lint fmt

# Clean build artifacts
clean:
    cargo clean
    rm -rf data/

# === Additional Targets ===

# Build debug binaries
build-dev:
    cargo build --workspace

# Run unit tests only
test-unit:
    cargo test --workspace --lib

# Run acceptance/integration tests
test-acceptance:
    cargo test --workspace --test '*'

# Run in standalone mode (local development)
run: build-release
    mkdir -p "{{ROOT}}/data"
    cd "{{ROOT}}" && cargo run \
        --bin angzarr-standalone \
        --features standalone,sqlite \
        -- --config examples/rust/standalone.yaml

# Run in standalone mode (debug build)
run-dev: build-dev
    mkdir -p "{{ROOT}}/data"
    cargo run --manifest-path "{{ROOT}}/Cargo.toml" \
        --bin angzarr-standalone \
        --features standalone,sqlite \
        -- --config "{{ROOT}}/standalone.yaml"
